{
  "name": "pcb-portale-consorzio-bonifica",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend",
    "connectors"
  ],
  "scripts": {
    "dev:prepare-runtime": "bash ./scripts/prepare-local-runtime.sh",
    "dev:stack": "docker compose up -d",
    "dev:up": "bash ./scripts/dev-up.sh",
    "dev:smoke": "bash ./scripts/smoke-local-runtime.sh",
    "dev:smoke:ingestion": "bash ./scripts/smoke-ingestion-runtime.sh",
    "dev:smoke:gis": "bash ./scripts/smoke-gis-runtime.sh",
    "dev:verify": "bash ./scripts/verify-local-runtime.sh",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:connectors": "npm run dev --workspace connectors",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
